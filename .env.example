# ==========================================================================
# wazup environment configuration
# Copy to .env and fill in real values. Never commit a filled-in .env.
# The production server keeps its own .env at /opt/wazup/.env — deploys
# never ship or overwrite it.
# ==========================================================================

# --- Core (required in every environment) ---
BETTER_AUTH_SECRET=a-random-string-at-least-32-characters-long
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Local development (single-process `pnpm dev`) ---
DATABASE_URL=postgres://wazup:wazup@localhost:5432/wazup
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=wazup
MINIO_USE_SSL=false
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me
API_URL=http://localhost:3000
WEB_URL=http://localhost:5173
NODE_ENV=development

# --- Production only (consumed by docker-compose.yml) ---
# DOMAIN drives the api/web/s3/lk hostnames and TLS certificates.
# In production the api container derives DATABASE_URL, REDIS_URL, MINIO_*,
# LIVEKIT_URL, API_URL and WEB_URL from the compose file, so the server .env
# only needs the values below plus the Core and shared secret keys above.
DOMAIN=example.com
POSTGRES_USER=wazup
POSTGRES_PASSWORD=change-me
POSTGRES_DB=wazup
