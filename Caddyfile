{$DOMAIN:localhost} {
    handle /api/* {
        reverse_proxy api:3000
    }

    handle /ws {
        reverse_proxy api:3000
    }

    handle {
        reverse_proxy web:80
    }
}

s3.{$DOMAIN:localhost} {
    reverse_proxy minio:9000
}

lk.{$DOMAIN:localhost} {
    reverse_proxy livekit:7880
}
